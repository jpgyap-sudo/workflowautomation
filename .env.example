# Core
TZ=Asia/Manila
GENERIC_TIMEZONE=Asia/Manila

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=quotation_automation

# n8n
N8N_HOST=automation.yourdomain.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://automation.yourdomain.com/
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me
# Agent reminder system uses _CHAT_ID suffix env vars (mapped in agentRunner.ts getGroupChatId())
PURCHASING_GROUP_CHAT_ID=-100000000001
PRODUCTION_GROUP_CHAT_ID=-100000000002
INVENTORY_GROUP_CHAT_ID=-100000000003
DELIVERY_GROUP_CHAT_ID=-100000000004
COLLECTION_GROUP_CHAT_ID=-100000000005
ESCALATION_GROUP_CHAT_ID=-100000000006
QUOTATION_GROUP_CHAT_ID=-100000000007
# Legacy _ID suffix vars (used by telegram-bot container only)
PURCHASING_GROUP_ID=-100000000001
INVENTORY_GROUP_ID=-100000000002
DELIVERY_GROUP_ID=-100000000003
COLLECTION_GROUP_ID=-100000000004

# Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_ID=replace_with_drive_folder_id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# Google Drive OAuth (for file uploads - service accounts have no storage quota)
# Run: node scripts/oauth-setup.mjs to generate these
# GOOGLE_DRIVE_CLIENT_ID=your-oauth-client-id
# GOOGLE_DRIVE_CLIENT_SECRET=your-oauth-client-secret
# GOOGLE_DRIVE_OAUTH_TOKEN_PATH=/app/credentials/oauth-token.json

# AI / OCR (optional)
OPENAI_API_KEY=sk-replace_me
GEMINI_API_KEY=replace_me
OPENROUTER_API_KEY=sk-or-v1-replace_me
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Dashboard URL (for Telegram bot to link to the vision page)
DASHBOARD_BASE_URL=https://your-domain.example.com

# Supabase Backup Storage
# Project: https://supabase.com/dashboard/project/your-supabase-project-id
# Get the service_role key from Project Settings > API
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_BACKUP_BUCKET=db-backups
# Backups are kept forever — no automatic deletion
# Optional: Telegram chat ID to receive backup failure alerts
# BACKUP_ALERT_CHAT_ID=-100000000000
