# ============================================================
# Quotation Automation System — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Core ──
TZ=Asia/Manila
GENERIC_TIMEZONE=Asia/Manila

# ── Postgres ──
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=quotation_automation

# ── n8n (legacy, not used by current stack) ──
N8N_HOST=automation.yourdomain.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://automation.yourdomain.com/
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=123456:replace_me

# Public webhook URL (must match your nginx domain)
PUBLIC_WEBHOOK_BASE_URL=https://your-domain.example.com

# Dashboard base URL (used by Telegram bot for dashboard links in vision extraction results)
# If not set, falls back to PUBLIC_WEBHOOK_BASE_URL, then https://track.abcx124.xyz
DASHBOARD_BASE_URL=https://your-domain.example.com

# ── Agent Group Chat IDs ──
# Agent reminder system uses _CHAT_ID suffix (mapped in agentRunner.ts getGroupChatId())
# ⚠️ IMPORTANT: Replace these with your actual Telegram group chat IDs.
# The values below are examples — do NOT use them in production.
# To get a group's chat ID: add @getidsbot to the group and type /id
PURCHASING_GROUP_CHAT_ID=-100000000001
PRODUCTION_GROUP_CHAT_ID=-100000000002
INVENTORY_GROUP_CHAT_ID=-100000000003
DELIVERY_GROUP_CHAT_ID=-100000000004
COLLECTION_GROUP_CHAT_ID=-100000000005
ESCALATION_GROUP_CHAT_ID=-100000000006
SCHEDULE_GROUP_CHAT_ID=-100000000008
STAGE_TRANSITION_GROUP_CHAT_ID=-100000000007
# Telegram chat that receives the 4-digit action verification codes from the GUI.
# Set to your personal Telegram chat ID for private delivery, or leave unset
# to fall back to ESCALATION_GROUP_CHAT_ID → PRODUCTION_GROUP_CHAT_ID → COLLECTION_GROUP_CHAT_ID.
ACTION_VERIFY_TELEGRAM_CHAT_ID=

# Legacy _ID suffix vars (used by telegram-bot container for group authorization)
PURCHASING_GROUP_ID=-100000000001
PRODUCTION_GROUP_ID=-100000000002
INVENTORY_GROUP_ID=-100000000003
DELIVERY_GROUP_ID=-100000000004
COLLECTION_GROUP_ID=-100000000005
ESCALATION_GROUP_ID=-100000000006
SCHEDULE_GROUP_ID=-100000000008
QUOTATION_GROUP_ID=-100000000007

# ── AI / OCR ──
OPENAI_API_KEY=sk-replace_me
# Gemini key — used as fallback when OpenRouter is unavailable
GEMINI_API_KEY_4=
# OpenRouter — primary AI provider (Gemini 2.0 Flash via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-replace_me
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
OPENROUTER_CHAT_MODEL=google/gemini-2.0-flash-001

# ── SMTP (Email notifications) ──
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ── Dashboard URL (for Telegram bot to link to the vision page) ──
DASHBOARD_BASE_URL=https://your-dashboard.example.com

# ── Supabase Backup Storage ──
# Project: https://supabase.com/dashboard/project/your-supabase-project-id
# Get the service_role key from Project Settings > API
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_BACKUP_BUCKET=db-backups
# Backups are kept forever — no automatic deletion
# Optional: Telegram chat ID to receive backup failure alerts
# BACKUP_ALERT_CHAT_ID=-100000000000
